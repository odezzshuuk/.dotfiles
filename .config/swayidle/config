# Assumes swaylock is the session locker.
before-sleep ''
after-resume ''

timeout 5 'echo "Going to sleep"'

# screen dark
timeout 600 'brightnessctl -s set 10' resume 'brightnessctl -r'

# lock screen
timeout 900 'loginctl lock-session'

# turn off screen
timeout 1200 'niri msg action power-off-monitors' resume 'niri msg action power-on-monitors'

# suspend
timeout 1800 'systemctl suspend'

